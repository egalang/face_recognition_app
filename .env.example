APP_NAME=Student Face Recognition API
APP_VERSION=0.1.0
DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./data/student_face_api.db
STORAGE_DIR=./data
ODOO_BASE_URL=http://host.docker.internal:8069
ODOO_ACCESS_TOKEN=
ODOO_TIMEOUT_SECONDS=30
ODOO_STUDENT_SYNC_ENDPOINT=/api/students/enrollments
ODOO_ATTENDANCE_LOG_ENDPOINT=/api/attendance/log
RECOGNITION_TOLERANCE=0.48
ANTI_SPOOFING_ENABLED=false
ADMIN_API_KEY=change-me
